// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

enum BookingStatus {
  held
  confirmed
  cancelled
  completed
}

enum ReviewStatus {
  pending
  approved
}

model Booking {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Person booking the appointment.
  name  String
  email String
  notes String?

  // When the appointment runs (UTC).
  startAt DateTime
  endAt   DateTime

  // Client phone number.
  phone String?

  // Per-booking buffer in minutes before and after the appointment.
  bufferBeforeMin Int @default(0)
  bufferAfterMin  Int @default(0)

  // Booking lifecycle state and hold expiry.
  status        BookingStatus @default(confirmed)
  holdExpiresAt DateTime?

  // Secret tokens for cancel and review magic links.
  cancelToken String @unique
  reviewToken String @unique @default(uuid())

  // Double-booking prevention: set to startAt.toISOString() when active (held/confirmed),
  // set to "released:<id>" when cancelled or expired so the slot is freed without null collisions.
  activeSlotKey String? @unique

  // Google Calendar event ID, used to delete the event on cancellation.
  calendarEventId String?

  // Review email tracking.
  reviewSentAt      DateTime? // When the review request email was sent
  reviewSubmittedAt DateTime? // When the client submitted a review

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Expired hold cleanup cron: WHERE status="held" AND holdExpiresAt <= now
  @@index([status, holdExpiresAt])
  // Slot availability (slots, days, request, booking page): WHERE status IN [held,confirmed] AND endAt >= now
  @@index([status, endAt])
  // Review email cron and admin page: filter/sort on reviewSentAt
  @@index([reviewSentAt])
  // Review email cron: WHERE status="confirmed" AND reviewSentAt=null AND endAt<=threshold
  @@index([status, reviewSentAt, endAt])
  // Contact/admin lookup by phone
  @@index([phone])
}

model Review {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  text        String
  firstName   String?
  lastName    String?
  isAnonymous Boolean @default(false)

  // Moderation state.
  status ReviewStatus @default(pending)

  // Optional reference used for magic-link edit/auth.
  customerRef String?

  // Optional link to the originating booking (verified reviews only).
  bookingId String? @db.ObjectId
  verified  Boolean @default(false)

  // Optional link to a Contact record (matched by email or set manually).
  contactId String? @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Public and admin review listing: WHERE status="approved" ORDER BY createdAt DESC
  @@index([status, createdAt(sort: Desc)])
  // Contacts tab: group reviews by contactId
  @@index([contactId])
}

// Standalone review requests sent to past clients by email or SMS.
model ReviewRequest {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  email             String? // Null for SMS-only records; used for deduplication
  phone             String? // Null for email-only records; used for deduplication
  reviewToken       String    @unique @default(uuid())
  reviewSubmittedAt DateTime?
  createdAt         DateTime  @default(now())

  // Admin page listing: ORDER BY createdAt DESC
  @@index([createdAt(sort: Desc)])
  // Deduplication before sending a new review link
  @@index([email])
  @@index([phone])
}

// Contacts built from booking submissions.
model Contact {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  email           String?
  phone           String?
  address         String?
  googleContactId String? // Google People API resource name (e.g. "people/c1234567890")
  // Stable per-contact review URL token. Lazy-filled by ensureContactReviewToken
  // so the same review link appears on every invoice the customer receives.
  // Not @unique because MongoDB's unique index rejects multiple null values
  // during backfill; UUID v4 collisions are vanishingly rare.
  reviewToken     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Travel time blocks created for external calendar events with a location.
model TravelBlock {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  sourceEventId        String
  calendarEmail        String
  summary              String? // Google Calendar event title (e.g. "Dentist", "Mario Movie")
  eventStartAt         DateTime // Source event start - used to detect time changes
  eventEndAt           DateTime // Source event end - used to detect time changes
  rawTravelMinutes     Int? // Raw travel-to time from Distance Matrix API
  roundedMinutes       Int? // Rounded travel-to value used for block window
  rawTravelBackMinutes Int? // Raw return-trip travel time
  roundedBackMinutes   Int? // Rounded return-trip value used for block window
  beforeEventId        String? // Synthetic CalendarEventCache ID blocking travel-to
  afterEventId         String? // Synthetic CalendarEventCache ID blocking travel-back
  transportMode        String? // "transit" | "driving" | "walking" | "bicycling" - null treated as "transit"
  customOrigin         String? // Manual override for travel-to origin address
  detectedOrigin       String? // Auto-detected origin from preceding event or home address
  destination          String? // Destination address (event.location ?? event.summary)
  createdAt            DateTime @default(now())

  @@unique([sourceEventId, calendarEmail])
}

// Cached Google Calendar events for fast booking page loads.
model CalendarEventCache {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  eventId       String // Google Calendar event ID
  calendarEmail String // Which calendar this event belongs to
  startAt       DateTime // Event start (UTC)
  endAt         DateTime // Event end (UTC)

  fetchedAt DateTime @default(now()) // When this entry was cached
  expiresAt DateTime // When this entry should be refreshed

  // Upsert by natural key
  @@unique([eventId, calendarEmail])
  // Cache cleanup cron: WHERE expiresAt < now
  @@index([expiresAt])
  // Booking page query: WHERE endAt >= now AND expiresAt > now
  @@index([endAt, expiresAt])
}

// --- Business module ---

// A RateConfig row is exactly one of three kinds, distinguished by which
// numeric field is set:
//   - Base hourly rate: ratePerHour set (e.g. Standard $65/hr).
//   - Modifier: hourlyDelta set (signed $/hr added to the base when applied,
//     e.g. -10 for At home, +20 for Complex). Stacked freely per task.
//   - Flat rate: flatRate set (e.g. Travel $1.20/km).
// The effective unit price for an hourly task is base.ratePerHour + sum of
// applied modifier deltas.
model RateConfig {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  label       String
  ratePerHour Float?
  flatRate    Float?
  hourlyDelta Float?
  unit        String   @default("hour")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
}

type LineItem {
  description String
  qty         Float
  unitPrice   Float
  lineTotal   Float
}

model Invoice {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  number      String        @unique
  clientName  String
  clientEmail String
  issueDate   DateTime
  dueDate     DateTime
  lineItems   LineItem[]
  gst         Boolean       @default(false)
  subtotal    Float
  gstAmount   Float
  total       Float
  // Promo snapshot at creation time (kept stable if the source promo changes).
  promoTitle    String?
  promoDiscount Float?
  status      InvoiceStatus @default(DRAFT)
  notes       String?
  contactId   String?       @db.ObjectId
  driveFileId String?
  driveWebUrl String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model IncomeEntry {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  date        DateTime
  customer    String
  description String
  amount      Float
  method      String
  notes       String?
  invoiceId   String?  @db.ObjectId
  // Stable identifier shared with the corresponding row in the per-FY Google Sheet
  // (Cashbook tab, hidden column Z). Set when the entry is first written to a sheet
  // or backfilled by the import. Used for upsert-by-id sync in both directions.
  // Not @unique because MongoDB's unique index rejects multiple null values during
  // backfill; collisions are vanishingly unlikely with crypto.randomUUID().
  sheetRowKey String?
  createdAt   DateTime @default(now())

  @@index([sheetRowKey])
}

model ExpenseEntry {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  date        DateTime
  supplier    String
  description String
  category    String
  amountIncl  Float
  gstAmount   Float
  amountExcl  Float
  method      String
  receipt     Boolean  @default(false)
  notes       String?
  // Stable identifier shared with the corresponding row in the per-FY Google Sheet
  // (Expenses tab, hidden column Z). See IncomeEntry.sheetRowKey for details.
  sheetRowKey String?
  createdAt   DateTime @default(now())

  @@index([sheetRowKey])
}

// Singleton-ish key/value store for small pieces of cross-app config that
// previously lived in the Google Sheet SETTINGS tab (e.g. the invoice counter).
model Setting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model TaskTemplate {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  description  String
  defaultPrice Float
  usageCount   Int      @default(1)
  // Free-text device the task targets (e.g. "Laptop", "Phone", "Email account").
  // Open vocabulary - any string the operator types or the AI emits is accepted.
  device       String?
  // Free-text action describing what was done (e.g. "Setup", "Repair", "Recovery").
  // Same open vocabulary as device. Combined with device to compose the
  // line-item description: "<device> <action lowercased>".
  action       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Calculator filters by device/action, so index both for fast lookups.
  @@index([device])
  @@index([action])
}

// Customer-facing promotional discount that applies during a date window.
// At any time, at most one Promo is "currently active" (isActive AND startAt
// <= now < endAt); when multiple overlap the most recently created wins.
//
// Exactly one of `flatHourlyRate` / `percentDiscount` must be set:
//   - flatHourlyRate: replaces the labor $/hr while active (e.g. 50 = $50/hr).
//   - percentDiscount: 0..1, multiplied against the labor subtotal.
// The active promo is applied to labor only (tasks + top-level Time charge);
// parts and Travel are never discounted.
model Promo {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  description     String?
  startAt         DateTime
  endAt           DateTime
  flatHourlyRate  Float?
  percentDiscount Float?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // getActivePromo() filters by these three; covers most lookups.
  @@index([isActive, startAt, endAt])
}

// Per-task split returned by the public price estimator AI (one entry per
// distinct task in a multi-task description). `mins` is the task's STACKED
// contribution to the combined visit, not its standalone benchmark.
type EstimateTask {
  label String
  mins  Int
}

// Audit log for the public price estimator. Captures what the user typed,
// how the AI interpreted it, and the exact range shown on screen so disputes
// can be reviewed. Purged after 30 days by /api/cron/purge-price-estimates.
model PriceEstimateLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Raw user input from the wizard step 1.
  description String

  // AI output captured verbatim.
  aiEstimatedMins Int
  aiCategory      String // "standard" | "complex"
  aiExplanation   String
  aiTasks         EstimateTask[]

  // Address + drive time (step 2 is optional - skipped values stay null).
  address    String?
  travelMins Int?

  // Final price range shown to the user, post-promo.
  hourlyRate Float
  priceLow   Int
  priceHigh  Int

  // Promo snapshot so old quotes remain reconstructable after promos change.
  promoTitle String?
  promoLabel String?

  // NODE_ENV at the time of the request - "production" for real public
  // traffic, "development" when I hit the wizard from `npm run dev`. The
  // admin page hides non-production rows by default and exposes a toggle
  // so I can audit my own test submissions when I need to.
  environment String @default("production")

  createdAt DateTime @default(now())

  // Cron cleanup: WHERE createdAt < now - 30d
  @@index([createdAt])
  // Admin page default view: WHERE environment="production" ORDER BY createdAt DESC
  @@index([environment, createdAt(sort: Desc)])
}

model Subscription {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  description String
  supplier    String
  category    String   @default("Subscriptions")
  amountIncl  Float
  gstRate     Float    @default(0.15)
  method      String   @default("Business Account")
  frequency   String
  nextDue     DateTime
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, nextDue])
}
