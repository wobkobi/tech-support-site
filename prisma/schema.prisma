// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

enum BookingStatus {
  held
  confirmed
  cancelled
  completed
}

enum ReviewStatus {
  pending
  approved
  revoked
}

model Booking {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Person booking the appointment.
  name  String
  email String
  notes String?

  // When the appointment runs (UTC).
  startAt DateTime
  endAt   DateTime

  // Per-booking buffer in minutes before and after the appointment.
  bufferBeforeMin Int @default(0)
  bufferAfterMin  Int @default(0)

  // Booking lifecycle state and hold expiry.
  status         BookingStatus @default(confirmed)
  holdExpiresAt DateTime?

  // Secret tokens for cancel and review magic links.
  cancelToken String  @unique
  reviewToken String  @unique @default(uuid())

  // Double-booking prevention: set to startAt.toISOString() when active (held/confirmed),
  // null when cancelled or expired. Sparse unique index only enforces uniqueness on
  // non-null values, so multiple cancelled bookings can coexist safely.
  activeSlotKey String? @unique

  // Google Calendar event ID, used to delete the event on cancellation.
  calendarEventId String?

  // Review email tracking.
  reviewSentAt      DateTime? // When the review request email was sent
  reviewSubmittedAt DateTime? // When the client submitted a review

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Expired hold cleanup cron: WHERE status="held" AND holdExpiresAt <= now
  @@index([status, holdExpiresAt])
  // Cancellation flow: look up by Google Calendar event ID
  @@index([calendarEventId])
  // Slot availability (slots, days, request, booking page): WHERE status IN [held,confirmed] AND endAt >= now
  @@index([status, endAt])
  // Review email cron and admin page: filter/sort on reviewSentAt
  @@index([reviewSentAt])
  // Review email cron: WHERE status="confirmed" AND reviewSentAt=null AND endAt<=threshold
  @@index([status, reviewSentAt, endAt])
}

model Review {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  text        String
  firstName   String?
  lastName    String?
  isAnonymous Boolean @default(false)

  // Moderation state.
  status ReviewStatus @default(pending)

  // Optional reference used for magic-link edit/auth.
  customerRef String?

  // Optional link to the originating booking (verified reviews only).
  bookingId String? @db.ObjectId
  verified  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Public and admin review listing: WHERE status="approved" ORDER BY createdAt DESC
  @@index([status, createdAt(sort: Desc)])
}

// Standalone review requests sent to past clients by email or SMS.
model ReviewRequest {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  email             String?   // Null for SMS-only records; used for deduplication
  phone             String?   // Null for email-only records; used for deduplication
  reviewToken       String    @unique @default(uuid())
  reviewSubmittedAt DateTime?
  createdAt         DateTime  @default(now())

  // Admin page listing: ORDER BY createdAt DESC
  @@index([createdAt(sort: Desc)])
  // Deduplication before sending a new review link
  @@index([email])
  @@index([phone])
}

// Cached Google Calendar events for fast booking page loads.
model CalendarEventCache {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  eventId       String   // Google Calendar event ID
  calendarEmail String   // Which calendar this event belongs to
  startAt      DateTime // Event start (UTC)
  endAt        DateTime // Event end (UTC)

  fetchedAt DateTime @default(now()) // When this entry was cached
  expiresAt DateTime                 // When this entry should be refreshed

  // Cache cleanup cron: WHERE expiresAt < now
  @@index([expiresAt])
  // Upsert by natural key
  @@unique([eventId, calendarEmail])
  // Booking page query: WHERE endAt >= now AND expiresAt > now
  @@index([endAt, expiresAt])
}
