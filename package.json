{
  "name": "tech-support-site",
  "version": "1.7.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "simple-git-hooks",
    "postinstall": "prisma generate",
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "db:push": "prisma db push",
    "seed": "tsx prisma/seed.ts",
    "lint": "eslint \"{src,tests,scripts}/**/*.{js,ts,jsx,tsx}\"",
    "format": "prettier --write \"**/*.{js,ts,jsx,tsx,mjs,css,html,md,json,yml,yaml}\"",
    "build:icons": "tsx scripts/build-icons/index.ts",
    "build:poster": "npx tsx scripts/export-poster-screenshot.ts",
    "build:all": "npm run build:icons && npm run build",
    "test": "vitest",
    "smoke": "tsx scripts/smoke-test.ts",
    "smoke:fast": "tsx scripts/smoke-test.ts --skip-build"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "googleapis": "^171.4.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "resend": "^6.9.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.0.0",
    "@next/bundle-analyzer": "^16.2.1",
    "@prisma/client": "6.19.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/google.maps": "^3.58.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "canvas": "^3.2.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.8.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^6.19.2",
    "puppeteer": "^24.40.0",
    "qr-code-styling": "^1.9.2",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "latest",
    "vitest": "^4.1.1"
  },
  "browserslist": [
    "chrome >= 93",
    "firefox >= 92",
    "safari >= 15.4",
    "edge >= 93"
  ],
  "browserslistNote": "These minimum versions target modern evergreen browsers (Chrome/Edge 93+, Firefox 92+, Safari 15.4+) that fully support ES2021+, modern CSS (including grid/flexbox), and Next.js 16 features. This aligns with the project's browser support policy of supporting roughly the last 3 years of auto-updating browsers while excluding legacy browsers such as Internet Explorer.",
  "engines": {
    "node": "22.x",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "@typescript-eslint/typescript-estree": {
      "minimatch": "^10.2.1"
    },
    "glob": {
      "minimatch": "^10.2.1"
    }
  },
  "simple-git-hooks": {
    "pre-commit": "npm install && npx lint-staged",
    "pre-push": "npm run smoke:fast"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings=0"
    ],
    "**/*.{css,html,json,md,mjs,yml,yaml}": "prettier --write"
  }
}
