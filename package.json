{
  "name": "tech-support-site",
  "version": "4.5.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build --turbopack",
    "build:ads": "tsx scripts/build-ads.ts",
    "build:all": "npm run build:icons && npm run build",
    "build:icons": "tsx scripts/build-icons/index.ts",
    "build:poster": "npx tsx scripts/export-poster-screenshot.ts",
    "calibrate": "dotenv -e .env.local -- tsx scripts/calibrate-benchmarks.ts",
    "db:push": "prisma db push",
    "dev": "next dev --turbopack",
    "eval:ai": "dotenv -e .env.local -- tsx scripts/eval-ai/index.ts",
    "format": "prettier --write \"**/*.{js,ts,jsx,tsx,mjs,css,html,md,json,yml,yaml}\"",
    "postinstall": "prisma generate",
    "lint": "eslint \"{src,scripts}/**/*.{js,ts,jsx,tsx}\"",
    "lint:fix": "eslint --fix \"{src,scripts}/**/*.{js,ts,jsx,tsx}\"",
    "prepare": "simple-git-hooks",
    "settings:seed": "dotenv -e .env.local -- tsx scripts/seed-settings.ts",
    "smoke": "dotenv -e .env.local -- tsx scripts/smoke-test.ts",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "simple-git-hooks": {
    "pre-commit": "npm install --package-lock-only && git add package-lock.json package.json && npx lint-staged && npm run typecheck",
    "pre-push": "npm run lint && npm run build && npm run smoke -- --skip-build"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "**/*.{css,html,json,md,mjs,yml,yaml}": "prettier --write"
  },
  "browserslist": [
    "chrome >= 93",
    "firefox >= 92",
    "safari >= 15.4",
    "edge >= 93"
  ],
  "overrides": {
    "postcss": "$postcss",
    "sharp": "$sharp"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@swc/helpers": "^0.5.23",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "date-holidays": "^3.33.0",
    "googleapis": "^173.0.0",
    "next": "^16.2.11",
    "openai": "^6.48.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-icons": "^5.7.0",
    "resend": "^6.18.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@next/bundle-analyzer": "^16.2.11",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/google.maps": "^3.65.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "canvas": "^3.2.3",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.11",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.2.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-tailwind-canonical-classes": "^1.4.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.1",
    "png-to-ico": "^3.0.2",
    "postcss": "^8.5.21",
    "prettier": "^3.9.6",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "prisma": "6.19.3",
    "puppeteer": "^25.3.0",
    "qr-code-styling": "^1.9.2",
    "sharp": "^0.35.3",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "engines": {
    "node": "24.x",
    "npm": ">=10.0.0"
  }
}
