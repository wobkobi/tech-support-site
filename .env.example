# Copy to .env.local (dev) or .env.production.local (prod) and fill in real values.
# Values containing literal "$" must be single-quoted with "\$" so dotenv-expand
# does not try to interpolate them (Next.js loads via dotenv-expand on every env).

# --- Core ---
MONGODB_URI="mongodb+srv://USER:PASS@CLUSTER/tech-support-site"
NEXT_PUBLIC_SITE_URL="https://example.com"
NEXT_PUBLIC_BUSINESS_GST_NUMBER=""
NEXT_PUBLIC_BUSINESS_BANK_ACCOUNT=""

# --- Analytics / Google Ads (NEXT_PUBLIC_*, inlined into the client at build) ---
# GA4 measurement ID (G-XXXXXXX). Optional; enables Google Analytics.
NEXT_PUBLIC_GA4_ID=""
# Google Ads tag ID (AW-XXXXXXX). Enables Ads conversion tracking + remarketing.
NEXT_PUBLIC_GOOGLE_ADS_ID=""
# Conversion label for a completed booking - the part after the slash in the Ads
# "send_to" value (AW-XXXXXXX/<label>). Fired once on /booking/success.
NEXT_PUBLIC_GOOGLE_ADS_BOOKING_LABEL=""
# Conversion label for a phone-link tap. Optional; fired on any tel: click.
NEXT_PUBLIC_GOOGLE_ADS_CALL_LABEL=""

# --- Auth ---
# Admin password the operator types into /admin/login (also the HMAC signing
# key for the session cookie + the X-Admin-Secret header for scripts/cron-like
# callers). Rotating invalidates every active session.
ADMIN_SECRET="change-me"
# Bearer token expected by /api/cron/* endpoints (header: Authorization: Bearer ...).
# Single-quote + escape $ literally:  CRON_SECRET='abc\$def'
CRON_SECRET="change-me"

# --- Email (Resend) ---
RESEND_API_KEY=""
EMAIL_FROM="Bookings <noreply@example.com>"
ADMIN_EMAIL="owner@example.com"

# --- OpenAI ---
OPENAI_API_KEY=""

# --- Google Maps / Distance Matrix ---
# Used by /api/pricing/travel-time, parse-job travel lookup, and the address
# autocomplete. The route returns 503 when either of these is unset.
GOOGLE_MAPS_API_KEY=""
HOME_ADDRESS=""

# --- Google Calendar (OAuth) ---
BOOKING_CALENDAR_ID=""
WORK_CALENDAR_ID=""
PERSONAL_CALENDAR_ID=""
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI=""
GOOGLE_OAUTH_REFRESH_TOKEN=""

# --- Google Sheets / Drive (business module) ---
GOOGLE_SHEET_ID=""
GOOGLE_BUSINESS_SHEETS_FOLDER_ID=""
